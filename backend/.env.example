# Copy to .env and fill in real values.

# REQUIRED — the app refuses to start without it.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# JWT lifetime in minutes (default 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated list of allowed browser origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Any localhost port is also allowed by default (vite bumps ports when busy).
# Set to an empty string to disable, or provide your own regex.
# CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$

# Defaults to a local SQLite file when unset
# DATABASE_URL=postgresql+psycopg2://astro:astro@localhost:5432/astroplanner
