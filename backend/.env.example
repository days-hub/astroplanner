# Copy to .env and fill in real values.

# REQUIRED — the app refuses to start without it.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# JWT lifetime in minutes (default 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated list of allowed browser origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Any localhost port is also allowed by default (vite bumps ports when busy).
# Set to an empty string to disable, or provide your own regex.
# CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$

# Defaults to a local SQLite file when unset
# DATABASE_URL=postgresql+psycopg2://astro:astro@localhost:5432/astroplanner

# OPTIONAL — enables the "Sky advisor" natural-language recommendations.
# Get a key at https://platform.claude.com. Leave unset to run without it.
# ANTHROPIC_API_KEY=sk-ant-...
# ADVISOR_MODEL=claude-opus-4-8

# --- Demo mode ---------------------------------------------------------------
# DEMO_MODE=true exposes POST /demo/start, which mints a throwaway seeded
# account and logs a visitor straight into a populated dashboard. A public
# portfolio deploy pairs it with ALLOW_REGISTRATION=false so no stranger PII
# lands in the DB while the JWT auth + ownership isolation stay live.
# DEMO_MODE=false
# ALLOW_REGISTRATION=true
# DEMO_TOKEN_EXPIRE_MINUTES=120     # demo JWT lifetime
# DEMO_USER_TTL_HOURS=24            # demo accounts (+ seeded rows) purged past this age
# RATE_LIMIT_DEMO_PER_HOUR=6        # per-IP cap on demo-account creation
# RATE_LIMIT_DEMO_ADVISOR_PER_DAY=5 # tighter advisor cap for demo users (vs 25)

# Optional rate-limit overrides (defaults shown)
# RATE_LIMIT_LOGIN_PER_MIN=10
# RATE_LIMIT_REGISTER_PER_HOUR=10
# RATE_LIMIT_ADVISOR_PER_MIN=5
# RATE_LIMIT_ADVISOR_PER_DAY=25
