# Copy to .env (repo root) — used by docker-compose.

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Password for the Postgres container
POSTGRES_PASSWORD=

# Optional overrides
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# CORS_ORIGINS=http://localhost:8081

# Production only (docker-compose.prod.yml): public hostname for TLS
# DOMAIN=astro.example.com

# Demo mode: DEMO_MODE=true exposes POST /demo/start (throwaway seeded
# accounts); pair with ALLOW_REGISTRATION=false for a public portfolio deploy
# so no stranger PII is stored. See backend/.env.example for all demo knobs.
# DEMO_MODE=false
# ALLOW_REGISTRATION=true
# DEMO_USER_TTL_HOURS=24
# RATE_LIMIT_DEMO_PER_HOUR=6
# RATE_LIMIT_DEMO_ADVISOR_PER_DAY=5

# Optional rate-limit overrides (defaults: 10, 10, 5, 25)
# RATE_LIMIT_LOGIN_PER_MIN=10
# RATE_LIMIT_REGISTER_PER_HOUR=10
# RATE_LIMIT_ADVISOR_PER_MIN=5
# RATE_LIMIT_ADVISOR_PER_DAY=25

# OPTIONAL — enables the "Sky advisor" (LLM observing recommendations).
# Get a key at https://platform.claude.com; leave unset to run without it.
# After adding it: docker compose up -d backend
# ANTHROPIC_API_KEY=sk-ant-...
# ADVISOR_MODEL=claude-opus-4-8
